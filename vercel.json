{
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "functions": {
    "dist/server/index.js": {
      "runtime": "edge"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/dist/client/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/server/index.js"
    }
  ]
}